{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "rebaseWhen": "behind-base-branch",
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "description": "Use the OpenTofu registry for Terraform by default",
      "matchDatasources": ["terraform-provider", "terraform-module"],
      "registryUrls": ["https://registry.opentofu.org"]
    },
    {
      "description": "Use the Terraform registry for Terraform modules in the coder directory, as that uses Terraform not OpenTofu",
      "matchDatasources": ["terraform-provider", "terraform-module"],
      "matchFileNames": ["terraform/modules/coder/templates/**/src/*.tf"],
      "registryUrls": ["https://registry.terraform.io"]
    },
    {
      "description": "Group all Immich updates together",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/immich-app/**"],
      "groupName": "immich"
    },
    {
      "description": "Disable digest updates for Netbox, as they rebuild their image daily",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/netbox-community/netbox"],
      "matchUpdateTypes": ["digest"],
      "enabled": false
    }
  ],
  "kubernetes": {
    "managerFilePatterns": ["/flux/.+\\.ya?ml$/"]
  },
  "flux": {
    "managerFilePatterns": ["/flux/.+\\.ya?ml$/"]
  },
  "ignoreDeps": [
    "ghcr.io/fluxcd/helm-controller",
    "ghcr.io/fluxcd/image-automation-controller",
    "ghcr.io/fluxcd/image-reflector-controller",
    "ghcr.io/fluxcd/kustomize-controller",
    "ghcr.io/fluxcd/notification-controller",
    "ghcr.io/fluxcd/source-controller",
    "registry.fedoraproject.org/fedora",
    "registry.fedoraproject.org/fedora-minimal"
  ]
}
